# Comma-separated list of API keys, one per client machine.
# Generate with: openssl rand -hex 32
CLAUDE_COST_API_KEYS=key_for_machine_1,key_for_machine_2

# Server port (proxied by nginx at /dev/cost/)
PORT=5070

# Database path (default: ./data/cost.sqlite)
# DB_PATH=/var/lib/claude-cost/cost.sqlite
